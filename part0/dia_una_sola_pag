%%{init: {"layout": "elk"}}%%
flowchart TD
    A([Inicio]):::indigo --> B[Usuario abre la versión SPA]:::teal
    B --> C[La app carga notas existentes desde el servidor]:::teal
    C --> D[Usuario escribe una nueva nota en el campo de texto]:::violet
    D --> E[Usuario presiona Save]:::violet
    E --> F["La app envía POST /new_note_spa al servidor"]:::orange
    F --> G["Servidor responde con JSON de la nueva nota"]:::orange
    G --> H[La app actualiza la lista de notas sin recargar la página]:::green
    H --> I([Nota creada y mostrada en pantalla]):::green

    classDef indigo stroke:#818cf8,fill:#eef2ff;
    classDef teal stroke:#2dd4bf,fill:#f0fdfa;
    classDef violet stroke:#a78bfa,fill:#f5f3ff;
    classDef orange stroke:#fb923c,fill:#fff7ed;
    classDef green stroke:#4ade80,fill:#f0fdf4;
